# ===== Patrimoine — root env example =====
# Copy to .env and fill. Never commit real keys.

APP_ENV=local
APP_DEBUG=true
APP_PORT=8080
FRONTEND_PORT=3000

# Backend
APP_KEY=base64:REPLACE_WITH_php_artisan_key:generate
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# Database (PostgreSQL 16)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=patrimoine
DB_USERNAME=patrimoine
DB_PASSWORD=changeme
POSTGRES_PASSWORD=changeme

# Redis (cache + queue)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database

# Mail (dev: Mailpit)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@patrimoine.local
MAIL_FROM_NAME=Patrimoine

# Bootstrap admin (used by UserSeeder)
ADMIN_EMAIL=admin@patrimoine.local
ADMIN_PASSWORD=changeme-admin
ADMIN_NAME=Admin

# Pricing provider API keys (names referenced in price_providers.api_key_env)
PROVIDER_COINGECKO_KEY=
PROVIDER_GOLDAPI_KEY=
PROVIDER_EXCHANGERATE_KEY=
PROVIDER_TWELVEDATA_KEY=
PROVIDER_FINNHUB_KEY=
PROVIDER_OPENFIGI_KEY=

# AI Chat (OpenCode)
OPENCODE_PROVIDER=zen
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_TIMEOUT=90

# Reference currency
BASE_CURRENCY=EUR
